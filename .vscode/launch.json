{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend: FastAPI debug",
            "type": "debugpy",
            "request": "launch",
            // Windows: venv лежит в Scripts/. Для Linux/macOS — override ниже.
            "python": "${workspaceFolder}/backend/venv/Scripts/python.exe",
            "linux": {
                "python": "${workspaceFolder}/backend/venv/bin/python"
            },
            "osx": {
                "python": "${workspaceFolder}/backend/venv/bin/python"
            },
            "module": "uvicorn",
            "cwd": "${workspaceFolder}/backend",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYDEVD_USE_SYS_MONITORING": "0"
            },
            "args": [
                "main:app",
                "--host",
                "127.0.0.1",
                "--port",
                "8000",
                "--reload"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Backend: FastAPI reload",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}/backend",
            "command": ".\\venv\\Scripts\\python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000",
            "linux": {
                "command": "./venv/bin/python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000"
            },
            "osx": {
                "command": "./venv/bin/python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000"
            }
        },
        {
            "name": "Frontend: Vite dev",
            "type": "node-terminal",
            "request": "launch",
            "cwd": "${workspaceFolder}/frontend",
            "command": "npm run dev"
        }
    ],
    "compounds": [
        {
            "name": "All: Backend + Frontend",
            "configurations": [
                "Backend: FastAPI debug",
                "Frontend: Vite dev"
            ]
        }
    ]
}
